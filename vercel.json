{
  "version": 2,
  "buildCommand": "cd frontend && yarn install && yarn build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/scan.py": {}
  },
  "routes": [
    {
      "src": "/api/scan",
      "dest": "/api/scan.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
