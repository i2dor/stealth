{
  "version": 2,
  "buildCommand": "cd frontend && yarn install && yarn build",
  "outputDirectory": "frontend/dist",
  "builds": [
    {
      "src": "api/scan.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/scan",
      "dest": "/api/scan.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
