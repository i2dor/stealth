{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stealth",
  "version": "0.1.0",
  "identifier": "com.stealth.app",
  "build": {
    "beforeDevCommand": "cd frontend && yarn dev",
    "beforeBuildCommand": "cd frontend && yarn build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stealth — Bitcoin Privacy Analyzer",
        "width": 1024,
        "height": 768,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
